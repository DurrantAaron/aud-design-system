{
  "$description": "AuD design tokens. Constant neutrals, one moving accent per app. Canonical values are from the brand brief; dark surface/mid/rule are derived to complete the dark theme.",
  "color": {
    "neutral": {
      "light": {
        "ground":  { "value": "#F2F0EB", "role": "primary background — warm off-white", "canonical": true },
        "surface": { "value": "#FAFAF8", "role": "raised surfaces, cards", "canonical": true },
        "ink":     { "value": "#14130F", "role": "primary text; A/D of the mark on light", "canonical": true },
        "mid":     { "value": "#6B6960", "role": "secondary / muted text, labels", "canonical": true },
        "rule":    { "value": "#D8D4CC", "role": "borders, dividers, hairlines", "canonical": true }
      },
      "dark": {
        "ground":  { "value": "#17160F", "role": "primary background (dark)", "canonical": true },
        "ink":     { "value": "#F2F0EB", "role": "near-white text (dark)", "canonical": true },
        "surface": { "value": "#211F17", "role": "raised surfaces, cards (dark)", "canonical": false },
        "mid":     { "value": "#8E8B7F", "role": "muted text (dark)", "canonical": false },
        "rule":    { "value": "#2E2C22", "role": "hairlines (dark)", "canonical": false }
      }
    },
    "accent": {
      "brass":    { "value": "#C8A84B", "app": "flagship", "note": "flagship / signature" },
      "clay":     { "value": "#C26B52", "app": "care",     "note": "warm 'care' red" },
      "steel":    { "value": "#5E7C93", "app": "control",  "note": "muted night-blue" },
      "sage":     { "value": "#7C8A5C", "app": "ops",      "note": "desaturated olive" },
      "eucalypt": { "value": "#4F8A80", "app": "cleaning", "note": "muted teal" }
    },
    "semantic": {
      "$role": "Constant status colours across the suite (not the moving accent). base = solid/icon/border/chart, fg = text on tint, tint = chip/banner fill.",
      "light": {
        "success": { "base": "#557A4E", "fg": "#37512F", "tint": "#E7EDE1" },
        "warning": { "base": "#B5832E", "fg": "#6F501A", "tint": "#F2E9D2" },
        "danger":  { "base": "#B14C3A", "fg": "#732E22", "tint": "#F3E1DB" },
        "info":    { "base": "#4D6C88", "fg": "#314659", "tint": "#E0E7ED" }
      },
      "dark": {
        "success": { "base": "#8FB07F", "fg": "#C4D6B8", "tint": "#23291C" },
        "warning": { "base": "#D6AE5E", "fg": "#E6CE97", "tint": "#2C2415" },
        "danger":  { "base": "#D08172", "fg": "#E6B3A8", "tint": "#2C1C18" },
        "info":    { "base": "#8AA6BE", "fg": "#B6C8D8", "tint": "#1B232B" }
      }
    }
  },
  "typography": {
    "family": {
      "display": "Bebas Neue",
      "heading": "Barlow Condensed",
      "body": "Barlow",
      "mono": "Share Tech Mono"
    },
    "weight": {
      "heading": [300, 400, 600],
      "body": [400, 500, 600, 700],
      "mono": [400]
    },
    "size": {
      "xs": "0.6875rem", "sm": "0.8125rem", "base": "1rem",
      "lg": "1.25rem", "xl": "1.75rem", "2xl": "2.5rem", "3xl": "4rem"
    },
    "leading": { "tight": 1.1, "body": 1.5 },
    "tracking": { "label": "0.2em", "wide": "0.3em", "mark": "-0.02em", "tight": "-0.025em" }
  },
  "radius": { "sm": "2px", "base": "4px", "lg": "6px" },
  "hairline": "1px",
  "space": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "6": "24px", "8": "32px", "12": "48px", "16": "64px"
  },
  "shadow": {
    "$role": "Restrained, warm-tinted elevation. Rules still do structural work; reserve shadows for surfaces that float. Floating UI casts more than cards.",
    "sm": "0 1px 2px rgba(20, 19, 15, 0.06)",
    "base": "0 2px 8px rgba(20, 19, 15, 0.08)",
    "lg": "0 8px 24px rgba(20, 19, 15, 0.12)",
    "overlay": "0 12px 40px rgba(20, 19, 15, 0.18)"
  },
  "state": {
    "$role": "Interaction states. hover/press auto-flip with theme (ink-based); ring is accent-tinted.",
    "overlayHover": "color-mix(in srgb, var(--aud-ink) 6%, transparent)",
    "overlayPress": "color-mix(in srgb, var(--aud-ink) 12%, transparent)",
    "ring": "0 0 0 3px color-mix(in srgb, var(--aud-accent) 35%, transparent)",
    "disabledOpacity": 0.45
  },
  "scrim": "linear-gradient(to top, rgba(20,19,15,0.85) 0%, rgba(20,19,15,0.45) 35%, rgba(20,19,15,0) 70%)",
  "motion": {
    "$role": "Never linear. Three named curves + three durations. Direction convention: slide-up = temporary surface (sheet/toast), slide-in-from-left = forward progress through a flow.",
    "ease": {
      "snap": "cubic-bezier(0.2, 0, 0, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "smooth": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms" }
  },
  "colorDepth": {
    "$role": "Derived in CSS from --aud-accent + neutrals via color-mix; see tokens.css for the exact mix percentages. Starting points — tune freely.",
    "accentRamp": ["50", "100", "200", "300", "400", "500", "600", "700", "800", "900"],
    "accentRoles": { "base": "500", "hover": "700", "link": "400", "strong": "accent darkened toward ink for text-on-light (WCAG)" },
    "text": { "1": "primary (ink)", "2": "secondary (~80% ink)", "3": "tertiary (mid)" },
    "surfaceTint": "var(--aud-surface) + ~6% accent",
    "borderCard": "rule pushed ~30% toward ink (border-as-card-edge alternative to shadow)",
    "chart": {
      "1": "var(--aud-accent)", "2": "#5E7C93", "3": "#7C8A5C",
      "4": "#C26B52", "5": "#4F8A80", "6": "#9A7BA5"
    }
  }
}
